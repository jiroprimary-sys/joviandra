<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jovi Andra | Cinematic Editor</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <style>
        /* RESET */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #000;
            color: white;
            overflow-x: hidden;
            cursor: none; /* Hide default cursor for custom glow */
        }

        /* LOADER */
        #loader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #000;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            transition: opacity 0.5s ease;
        }

        .loader-text {
            font-size: 24px;
            letter-spacing: 6px;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0% { opacity: 0.2; }
            50% { opacity: 1; }
            100% { opacity: 0.2; }
        }

        /* NAV */
        nav {
            position: fixed;
            top: 30px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 40px;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            padding: 14px 40px;
            border-radius: 40px;
            z-index: 999;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        nav a {
            color: white;
            text-decoration: none;
            opacity: 0.8;
            font-size: 14px;
            font-weight: 500;
            transition: opacity 0.3s;
        }

        nav a:hover {
            opacity: 1;
        }

        /* HERO */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .hero iframe {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 120vw;
            height: 120vh;
            opacity: 0.35;
            pointer-events: none;
            z-index: 1;
        }

        .hero-content {
            z-index: 2;
            position: relative;
        }

        .hero h1 {
            font-size: 82px;
            letter-spacing: 10px;
            font-weight: 700;
            line-height: 1.1;
            margin-bottom: 20px;
        }

        .hero p {
            font-size: 18px;
            opacity: 0.8;
            font-weight: 300;
            letter-spacing: 1px;
        }

        .btn {
            display: inline-block;
            margin-top: 30px;
            padding: 14px 36px;
            background: white;
            color: black;
            border-radius: 30px;
            text-decoration: none;
            font-weight: 600;
            transition: transform 0.3s ease, background 0.3s;
        }

        .btn:hover {
            transform: scale(1.05);
            background: #e0e0e0;
        }

        /* SECTIONS */
        section {
            padding: 120px 10%;
            position: relative;
        }

        .section-title {
            font-size: 48px;
            margin-bottom: 60px;
            font-weight: 600;
            letter-spacing: -1px;
        }

        /* SHOWCASE */
        .netflix-row {
            display: flex;
            gap: 30px;
            overflow-x: auto;
            padding-bottom: 40px;
            /* Hide scrollbar for Chrome, Safari and Opera */
            -ms-overflow-style: none;  /* IE and Edge */
            scrollbar-width: none;  /* Firefox */
        }
        
        .netflix-row::-webkit-scrollbar {
            display: none;
        }

        .film {
            min-width: 420px;
            cursor: pointer;
            transition: transform 0.5s ease;
            position: relative;
            border-radius: 12px;
            overflow: hidden;
        }

        .film img {
            width: 100%;
            height: auto;
            display: block;
            border-radius: 12px;
        }

        .film:hover {
            transform: scale(1.05);
        }

        /* CLIENTS */
        .clients {
            display: flex;
            gap: 80px;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;
        }

        .clients img {
            height: 60px;
            filter: grayscale(100%);
            opacity: 0.7;
            transition: 0.3s;
        }

        .clients img:hover {
            filter: none;
            opacity: 1;
        }

        /* TIMELINE */
        .timeline-track {
            display: flex;
            gap: 60px;
            overflow-x: auto;
            padding-bottom: 20px;
        }

        .step {
            min-width: 260px;
            background: #111;
            padding: 30px;
            border-radius: 12px;
            transition: 0.4s;
            border: 1px solid #222;
        }

        .step:hover {
            transform: translateY(-10px);
            background: #1a1a1a;
            border-color: #333;
        }

        .step h3 {
            font-size: 24px;
            margin-bottom: 10px;
            color: #fff;
        }

        .step p {
            color: #aaa;
            font-size: 14px;
        }

        /* ABOUT */
        .about {
            max-width: 700px;
            opacity: 0.8;
            line-height: 1.7;
            font-size: 18px;
        }

        /* CONTACT */
        .contact {
            text-align: center;
            padding-bottom: 150px;
        }

        /* VIDEO MODAL */
        #modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: 0.4s;
            z-index: 2000;
        }

        #modal.active {
            opacity: 1;
            pointer-events: auto;
        }

        #modal iframe {
            width: 80%;
            height: 80%;
            border: none;
            border-radius: 8px;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
        }

        .close {
            position: absolute;
            top: 40px;
            right: 60px;
            font-size: 32px;
            cursor: pointer;
            color: white;
            transition: 0.3s;
        }

        .close:hover {
            color: #aaa;
        }

        /* CURSOR GLOW */
        .cursor-glow {
            position: fixed;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.08), transparent);
            pointer-events: none;
            mix-blend-mode: overlay;
            transform: translate(-50%, -50%);
            z-index: 9999;
            transition: width 0.3s, height 0.3s;
        }

        /* MOBILE RESPONSIVENESS */
        @media (max-width: 768px) {
            nav {
                width: 90%;
                justify-content: center;
                padding: 12px 20px;
                gap: 20px;
            }

            .hero h1 {
                font-size: 42px;
                letter-spacing: 5px;
            }

            .hero p {
                font-size: 14px;
            }

            section {
                padding: 80px 5%;
            }

            .section-title {
                font-size: 32px;
            }

            .film {
                min-width: 300px;
            }

            .cursor-glow {
                display: none; /* Disable custom cursor on touch devices */
            }
            
            body {
                cursor: auto;
            }
        }
    </style>
</head>

